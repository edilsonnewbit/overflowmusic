{
  "expo": {
    "name": "Overflow Music",
    "slug": "overflow-music",
    "scheme": "overflowmusic",
    "version": "1.0.0",
    "orientation": "portrait",
    "userInterfaceStyle": "automatic",
    "assetBundlePatterns": [
      "**/*"
    ],
    "ios": {
      "supportsTablet": true,
      "bundleIdentifier": "com.overflow.music"
    },
    "android": {
      "adaptiveIcon": {
        "backgroundColor": "#07101d"
      },
      "package": "com.overflow.music",
      "googleServicesFile": "./google-services.json",
      "permissions": ["RECEIVE_BOOT_COMPLETED", "VIBRATE", "POST_NOTIFICATIONS"]
    },
    "web": {
      "bundler": "metro"
    }
  }
}
