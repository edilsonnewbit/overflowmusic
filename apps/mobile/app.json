{
  "expo": {
    "name": "Overflow Music",
    "slug": "overflow-music",
    "owner": "overflow-movement",
    "scheme": "overflowmusic",
    "version": "1.0.0",
    "orientation": "portrait",
    "userInterfaceStyle": "automatic",
    "assetBundlePatterns": [
      "**/*"
    ],
    "ios": {
      "supportsTablet": true,
      "bundleIdentifier": "com.overflow.music"
    },
    "android": {
      "adaptiveIcon": {
        "backgroundColor": "#07101d"
      },
      "package": "com.overflow.music",
      "permissions": [
        "RECEIVE_BOOT_COMPLETED",
        "VIBRATE",
        "POST_NOTIFICATIONS"
      ]
    },
    "web": {
      "bundler": "metro"
    },
    "extra": {
      "eas": {
        "projectId": "4364d312-b105-4bed-b74f-c192ae1149a3"
      }
    }
  }
}
