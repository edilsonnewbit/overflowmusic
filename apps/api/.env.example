# API Configuration
PORT=3001
NODE_ENV=development

# Database
DATABASE_URL="postgresql://user:password@localhost:5432/overflow_music?schema=public"

# JWT Authentication
JWT_SECRET=your-super-secret-jwt-key-change-this-in-production

# Google OAuth
GOOGLE_CLIENT_ID=your-google-client-id.apps.googleusercontent.com

# Email Configuration (Gmail SMTP)
# Para obter SMTP_PASSWORD (Senha de App do Gmail):
# 1. Acesse: https://myaccount.google.com/security
# 2. Ative "Verificação em duas etapas" se ainda não estiver ativa
# 3. Acesse: https://myaccount.google.com/apppasswords
# 4. Gere uma nova senha de app para "Mail" e "Outro dispositivo"
# 5. Use a senha gerada (16 caracteres) no SMTP_PASSWORD
SMTP_USER=seu-email@gmail.com
SMTP_PASSWORD=sua-senha-de-app-16-caracteres
APP_NAME="Overflow Music"

# Frontend URL (para links em emails)
FRONTEND_URL=http://localhost:3000

# Redis (para queues)
REDIS_HOST=localhost
REDIS_PORT=6379
