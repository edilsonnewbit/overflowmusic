generator client {
  provider = "prisma-client-js"
}

datasource db {
  provider = "postgresql"
  url      = env("DATABASE_URL")
}

enum UserRole {
  SUPER_ADMIN
  ADMIN
  LEADER
  MEMBER
}

enum UserStatus {
  PENDING_APPROVAL
  APPROVED
  REJECTED
}

enum EventType {
  CULTO
  CONFERENCIA
  ENSAIO
  OUTRO
}

enum EventStatus {
  DRAFT
  ACTIVE
  PUBLISHED
  FINISHED
  ARCHIVED
}

enum MusicianSlotStatus {
  PENDING
  CONFIRMED
  DECLINED
  EXPIRED
}

enum ChordChartSourceType {
  TXT_IMPORT
  MANUAL
}

enum AuditionStatus {
  PENDING
  UNDER_REVIEW
  APPROVED
  REJECTED
}

model Audition {
  id               String        @id @default(uuid())
  name             String
  email            String
  whatsapp         String
  birthDate        String?
  city             String?
  church           String?
  pastorName       String?
  instagramProfile String?
  volunteerArea    String
  skills           String[]      @default([])
  availability     String[]      @default([])
  hasTransport     Boolean       @default(false)
  motivation       String?
  driveFileId      String?
  driveFileUrl     String?
  status           AuditionStatus @default(PENDING)
  adminNotes       String?
  reviewedAt       DateTime?
  reviewedBy       String?
  createdAt        DateTime      @default(now())
  updatedAt        DateTime      @updatedAt

  @@index([status])
  @@index([email])
  @@index([volunteerArea])
}

model User {
  id                String     @id @default(uuid())
  name              String
  email             String     @unique
  googleSub         String?    @unique
  passwordHash      String?
  emailVerified     Boolean    @default(false)
  emailVerifiedAt   DateTime?
  role              UserRole   @default(MEMBER)
  status            UserStatus @default(PENDING_APPROVAL)
  instruments       String[]   @default([])
  volunteerArea     String?
  instagramProfile  String?
  birthDate         DateTime?
  church            String?
  pastorName        String?
  whatsapp          String?
  address           String?
  photoUrl          String?
  volunteerTermsVersion    String?
  volunteerTermsAcceptedAt DateTime?
  createdAt         DateTime   @default(now())
  reviewedAt        DateTime?
  lastLoginAt       DateTime?

  pushTokens           PushToken[]
  memberships          OrganizationMember[]
  emailVerificationTokens EmailVerificationToken[]
  passwordResetTokens  PasswordResetToken[]
  eventMusicians       EventMusician[]

  @@index([status])
  @@index([emailVerified])
}

model EmailVerificationToken {
  id        String   @id @default(uuid())
  userId    String
  token     String   @unique
  expiresAt DateTime
  createdAt DateTime @default(now())
  user      User     @relation(fields: [userId], references: [id], onDelete: Cascade)

  @@index([userId])
  @@index([token])
}

model PasswordResetToken {
  id        String   @id @default(uuid())
  userId    String
  token     String   @unique
  expiresAt DateTime
  createdAt DateTime @default(now())
  usedAt    DateTime?
  user      User     @relation(fields: [userId], references: [id], onDelete: Cascade)

  @@index([userId])
  @@index([token])
}

model PushToken {
  id        String   @id @default(uuid())
  userId    String
  token     String   @unique
  platform  String?
  createdAt DateTime @default(now())
  updatedAt DateTime @updatedAt
  user      User     @relation(fields: [userId], references: [id], onDelete: Cascade)

  @@index([userId])
}

model Event {
  id                       String      @id @default(uuid())
  title                    String
  dateTime                 DateTime
  location                 String?
  address                  String?
  description              String?
  eventType                EventType   @default(CULTO)
  status                   EventStatus @default(DRAFT)
  confirmationDeadline     DateTime?
  confirmationDeadlineDays Int         @default(3)
  responseWindowHours      Int         @default(24)
  createdAt                DateTime    @default(now())
  updatedAt                DateTime    @updatedAt
  setlist                  Setlist?
  checklistRuns            ChecklistRun[]
  musicians                EventMusician[]
  instrumentConfigs        EventInstrumentConfig[]
  rehearsals               EventRehearsal[]
}

model EventInstrumentConfig {
  id             String   @id @default(uuid())
  eventId        String
  instrumentRole String
  requiredCount  Int      @default(1)
  createdAt      DateTime @default(now())
  updatedAt      DateTime @updatedAt
  event          Event    @relation(fields: [eventId], references: [id], onDelete: Cascade)

  @@unique([eventId, instrumentRole])
  @@index([eventId])
}

model EventMusician {
  id             String             @id @default(uuid())
  eventId        String
  instrumentRole String
  userId         String
  priority       Int
  status         MusicianSlotStatus @default(PENDING)
  notifiedAt     DateTime?
  respondedAt    DateTime?
  createdAt      DateTime           @default(now())
  updatedAt      DateTime           @updatedAt
  event          Event              @relation(fields: [eventId], references: [id], onDelete: Cascade)
  user           User               @relation(fields: [userId], references: [id], onDelete: Cascade)

  @@unique([eventId, instrumentRole, userId])
  @@index([eventId, instrumentRole, priority])
  @@index([eventId, status])
}

model Setlist {
  id        String        @id @default(uuid())
  eventId   String        @unique
  title     String?
  notes     String?
  createdAt DateTime      @default(now())
  updatedAt DateTime      @updatedAt
  event     Event         @relation(fields: [eventId], references: [id], onDelete: Cascade)
  items     SetlistItem[]
}

model SetlistItem {
  id              String   @id @default(uuid())
  setlistId       String
  order           Int
  songTitle       String
  key             String?
  leaderName      String?
  zone            String?
  transitionNotes String?
  createdAt       DateTime @default(now())
  updatedAt       DateTime @updatedAt
  setlist         Setlist  @relation(fields: [setlistId], references: [id], onDelete: Cascade)

  @@index([setlistId, order])
}

model Song {
  id          String       @id @default(uuid())
  title       String
  artist      String?
  defaultKey  String?
  zone        String?
  tags        Json?
  youtubeUrl  String?
  spotifyUrl  String?
  driveUrl    String?
  createdAt   DateTime     @default(now())
  updatedAt   DateTime     @updatedAt
  chordCharts ChordChart[]

  @@index([title])
  @@index([artist])
}

model ChordChart {
  id         String              @id @default(uuid())
  songId     String
  sourceType ChordChartSourceType @default(TXT_IMPORT)
  rawText    String
  parsedJson Json
  version    Int
  createdAt  DateTime            @default(now())
  song       Song                @relation(fields: [songId], references: [id], onDelete: Cascade)

  @@index([songId, version])
}

model ChecklistTemplate {
  id        String         @id @default(uuid())
  name      String
  items     Json
  createdAt DateTime       @default(now())
  updatedAt DateTime       @updatedAt
  runs      ChecklistRun[]

  @@index([name])
}

model ChecklistRun {
  id         String             @id @default(uuid())
  eventId    String
  templateId String?
  createdAt  DateTime           @default(now())
  updatedAt  DateTime           @updatedAt
  event      Event              @relation(fields: [eventId], references: [id], onDelete: Cascade)
  template   ChecklistTemplate? @relation(fields: [templateId], references: [id], onDelete: SetNull)
  items      ChecklistItemRun[]

  @@unique([eventId, templateId])
  @@index([eventId])
}

model ChecklistItemRun {
  id             String       @id @default(uuid())
  checklistRunId String
  label          String
  checked        Boolean      @default(false)
  checkedByName  String?
  checkedAt      DateTime?
  order          Int          @default(1)
  createdAt      DateTime     @default(now())
  updatedAt      DateTime     @updatedAt
  checklistRun   ChecklistRun @relation(fields: [checklistRunId], references: [id], onDelete: Cascade)

  @@index([checklistRunId, order])
}

enum OrgRole {
  OWNER
  ADMIN
  MEMBER
}

model Rehearsal {
  id              String    @id @default(uuid())
  title           String
  dateTime        DateTime
  location        String?
  address         String?
  description     String?
  notes           String?
  durationMinutes Int?      @default(60)
  createdAt       DateTime  @default(now())
  updatedAt       DateTime  @updatedAt
  events          EventRehearsal[]

  @@index([dateTime])
}

model EventRehearsal {
  eventId      String
  rehearsalId  String
  addedAt      DateTime  @default(now())
  event        Event      @relation(fields: [eventId],     references: [id], onDelete: Cascade)
  rehearsal    Rehearsal  @relation(fields: [rehearsalId], references: [id], onDelete: Cascade)

  @@id([eventId, rehearsalId])
  @@index([eventId])
  @@index([rehearsalId])
}

model Organization {
  id        String               @id @default(uuid())
  name      String
  slug      String               @unique
  createdAt DateTime             @default(now())
  updatedAt DateTime             @updatedAt
  members   OrganizationMember[]

  @@index([slug])
}

model OrganizationMember {
  id             String       @id @default(uuid())
  userId         String
  organizationId String
  role           OrgRole      @default(MEMBER)
  instrument     String?
  createdAt      DateTime     @default(now())
  user           User         @relation(fields: [userId], references: [id], onDelete: Cascade)
  organization   Organization @relation(fields: [organizationId], references: [id], onDelete: Cascade)

  @@unique([userId, organizationId])
  @@index([organizationId])
}

model AuditLog {
  id           String   @id @default(uuid())
  actorId      String?
  action       String
  resourceType String
  resourceId   String?
  metadata     Json?
  createdAt    DateTime @default(now())

  @@index([actorId])
  @@index([resourceType, resourceId])
}
