# ─── Mobile (Expo) ───────────────────────────────────────────────────────────
EXPO_PUBLIC_API_URL=https://music.seudominio.com/api
EXPO_PUBLIC_GOOGLE_CLIENT_ID=           # Web Client ID (fallback universal)
EXPO_PUBLIC_GOOGLE_WEB_CLIENT_ID=       # Web Client ID
EXPO_PUBLIC_GOOGLE_ANDROID_CLIENT_ID=   # Android OAuth Client ID
EXPO_PUBLIC_GOOGLE_IOS_CLIENT_ID=       # iOS OAuth Client ID
EXPO_PUBLIC_MOBILE_LOGIN_FALLBACK_ENABLED=false

# ─── API ──────────────────────────────────────────────────────────────────────
PORT=3001
DATABASE_URL=postgresql://user:pass@host:5432/db
JWT_SECRET=                             # OBRIGATÓRIO em prod (string longa e aleatória)
ADMIN_API_KEY=                          # Server-to-server bearer token
ADMIN_APPROVED_EMAILS=admin@seudominio.com
AUTH_BOOTSTRAP_MODE=false

# ─── Google OAuth (API) ───────────────────────────────────────────────────────
# GOOGLE_CLIENT_ID aceita um único Client ID
# GOOGLE_CLIENT_IDS aceita vários separados por vírgula (inclua Web, Android e iOS)
GOOGLE_CLIENT_ID=                       # Web Client ID
GOOGLE_CLIENT_IDS=                      # web-id,android-id,ios-id
GOOGLE_ALLOWED_DOMAIN=                  # Ex: meudominio.com (opcional)

# ─── Web (Next.js) ────────────────────────────────────────────────────────────
NEXT_PUBLIC_API_URL=https://music.seudominio.com/api
API_INTERNAL_URL=http://api:3001/api
WEB_LOGIN_FALLBACK_ENABLED=false
FRONTEND_URL=https://music.seudominio.com
NODE_ENV=production

# ─── Banco de dados ───────────────────────────────────────────────────────────
POSTGRES_PASSWORD=

# ─── Redis (opcional) ─────────────────────────────────────────────────────────
REDIS_PASSWORD=

# ─── SMTP (opcional) ──────────────────────────────────────────────────────────
SMTP_HOST=
SMTP_PORT=587
SMTP_USER=
SMTP_PASS=
SMTP_FROM=no-reply@seudominio.com

# ─── Docker ───────────────────────────────────────────────────────────────────
IMAGE_TAG=latest
